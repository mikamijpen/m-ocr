381.0]]], "lines": ["はぁ"]}, {"box": [1702, 751, 1811, 906], "vertical": true, "font_size": 109, "lines_coords": [[[1702.0, 751.0], [1811.0, 751.0], [1811.0, 906.0], [1702.0, 906.0]]], "lines": ["はっ"]}, {"box": [768, 429, 885, 614], "vertical": true, "font_size": 110, "lines_coords": [[[768.0, 432.0], [878.0, 429.0], [885.0, 611.0], [775.0, 614.0]]], "lines": ["はっ"]}, {"box": [76, 51, 495, 135], "vertical": false, "font_size": 37, "lines_coords": [[[291.0, 69.0], [473.0, 69.0], [473.0, 109.0], [291.0, 109.0]]], "lines": ["．．．"]}, {"box": [154, 137, 305, 1308], "vertical": true, "font_size": 151, "lines_coords": [[[154.0, 137.0], [305.0, 137.0], [305.0, 1308.0], [154.0, 1308.0]]], "lines": ["第９話久野とフジイ"]}, {"box": [1894, 1606, 2048, 1833], "vertical": true, "font_size": 154, "lines_coords": [[[1894.0, 1610.0], [2048.0, 1610.0], [2048.0, 1833.0], [1894.0, 1833.0]]], "lines": ["はっ"]}, {"box": [2045, 2434, 2211, 2729], "vertical": true, "font_size": 60, "lines_coords": [[[2089.0, 2434.0], [2141.0, 2485.0], [2093.0, 2530.0], [2045.0, 2482.0]], [[2130.0, 2455.0], [2189.0, 2455.0], [2189.0, 2729.0], [2130.0, 2729.0]]], "lines": ["？", "ＯＫですか"]}, {"box": [1163, 2448, 1403, 2757], "vertical": true, "font_size": 62, "lines_coords": [[[1328.0, 2448.0], [1403.0, 2448.0], [1403.0, 2588.0], [1328.0, 2588.0]], [[1276.0, 2448.0], [1341.0, 2448.0], [1341.0, 2616.0], [1276.0, 2616.0]], [[1218.0, 2451.0], [1276.0, 2451.0], [1276.0, 2757.0], [1218.0, 2757.0]], [[1163.0, 2455.0], [1211.0, 2455.0], [1211.0, 2729.0], [1163.0, 2729.0]]], "lines": ["いやー", "すげえ", "よかったよ！！", "気味悪くて。"]}, {"box": [899, 2451, 1025, 2758], "vertical": true, "font_size": 53, "lines_coords": [[[971.0, 2455.0], [1019.0, 2455.0], [1019.0, 2757.0], [971.0, 2757.0]], [[899.0, 2451.0], [957.0, 2451.0], [957.0, 2757.0], [899.0, 2757.0]]], "lines": ["この後、取材", "入ってます。"]}, {"box": [624, 2544, 703, 2709], "vertical": true, "font_size": 79, "lines_coords": [[[624.0, 2544.0], [703.0, 2544.0], [703.0, 2709.0], [624.0, 2709.0]]], "lines": ["了解。"]}, {"box": [1968, 3372, 2410, 3458], "vertical": false, "font_size": 94, "lines_coords": [[[1968.0, 3364.0], [2410.0, 3364.0], [2410.0, 3466.0], [1968.0, 3466.0]]], "lines": ["ロックスマイ・Ｓｅ．"]}, {"box": [1420, 3138, 1492, 3268], "vertical": true, "font_size": 49, "lines_coords": [[[1420.0, 3148.0], [1468.0, 3138.0], [1492.0, 3258.0], [1444.0, 3268.0]]], "lines": ["え！！"]}], "img_path": "page_002.jpg"}, {"version": "0.2.4", "img_width": 2481, "img_height": 3516, "blocks": [{"box": [1774, 226, 2110, 733], "vertical": true, "font_size": 58, "lines_coords": [[[2052.0, 233.0], [2110.0, 233.0], [2110.0, 583.0], [2052.0, 583.0]], [[1979.0, 233.0], [2038.0, 233.0], [2038.0, 573.0], [1979.0, 573.0]], [[1911.0, 233.0], [1969.0, 233.0], [1969.0, 628.0], [1911.0, 628.0]], [[1839.0, 226.0], [1897.0, 226.0], [1901.0, 731.0], [1842.0, 731.0]], [[1774.0, 230.0], [1832.0, 230.0], [1832.0, 628.0], [1774.0, 628.0]]], "lines": ["ヒサノさんは、", "映画・ドラマ・", "モデルに舞台と", "多岐にわたりご活躍", "されていますが"]}, {"box": [1156, 703, 1427, 793], "vertical": false, "font_size": 71, "lines_coords": [[[1156.0, 721.0], [1424.0, 703.0], [1427.0, 772.0], [1163.0, 793.0]]], "lines": ["ヒサノジョー"]}, {"box": [1183, 782, 1482, 896], "vertical": false, "font_size": 52.0, "lines_coords": [[[1183.0, 800.0], [1389.0, 782.0], [1393.0, 834.0], [1187.0, 851.0]], [[1187.0, 844.0], [1475.0, 806.0], [1482.0, 858.0], [1194.0, 896.0]]], "lines": ["「キャリアをたとる」", "「キャリアをたとる１万ギスンタビュー（奴）」"]}, {"box": [79, 48, 493, 133], "vertical": false, "font_size": 52, "lines_coords": [[[96.0, 57.0], [473.0, 57.0], [473.0, 113.0], [96.0, 113.0]]], "lines": ["Ｒａｍｌａｚｙ．Ｓｈ"]}, {"box": [1949, 1383, 2082, 1637], "vertical": true, "font_size": 65, "lines_coords": [[[2010.0, 1383.0], [2082.0, 1383.0], [2082.0, 1565.0], [2010.0, 1565.0]], [[1949.0, 1390.0], [2007.0, 1390.0], [2007.0, 1637.0], [1949.0, 1637.0]]], "lines": ["自分は", "運ですね。"]}, {"box": [1338, 1356, 1520, 1665], "vertical": true, "font_size": 55, "lines_coords": [[[1461.0, 1359.0], [1520.0, 1359.0], [1520.0, 1665.0], [1461.0, 1665.0]], [[1406.0, 1359.0], [1454.0, 1359.0], [1454.0, 1610.0], [1406.0, 1610.0]], [[1338.0, 1356.0], [1400.0, 1356.0], [1400.0, 1565.0], [1338.0, 1565.0]]], "lines": ["頂いた仕事を", "受けてきた", "だけで．．．"]}, {"box": [1050, 1476, 1293, 1881], "vertical": true, "font_size": 55, "lines_coords": [[[1242.0, 1479.0], [1293.0, 1479.0], [1293.0, 1634.0], [1242.0, 1634.0]], [[1180.0, 1476.0], [1238.0, 1476.0], [1238.0, 1833.0], [1180.0, 1833.0]], [[1122.0, 1479.0], [1170.0, 1479.0], [1170.0, 1881.0], [1122.0, 1881.0]], [[1050.0, 1476.0], [1108.0, 1476.0], [1115.0, 1703.0], [1056.0, 1703.0]]], "lines": ["自分で", "道を切り拓いて", "きたということは", "ないです。"]}, {"box": [322, 734, 609, 1077], "vertical": true, "font_size": 58, "lines_coords": [[[514.0, 734.0], [590.0, 734.0], [590.0, 923.0], [514.0, 923.0]], [[456.0, 741.0], [514.0, 741.0], [514.0, 1023.0], [456.0, 1023.0]], [[391.0, 745.0], [439.0, 745.0], [439.0, 1074.0], [391.0, 1074.0]], [[322.0, 745.0], [370.0, 745.0], [370.0, 1074.0], [322.0, 1074.0]]], "lines": ["秘訣や", "ポリシーの", "ようなものは", "ありますか？"]}, {"box": [531, 1521, 593, 1827], "vertical": true, "font_size": 59, "lines_coords": [[[531.0, 1521.0], [590.0, 1521.0], [590.0, 1826.0], [531.0, 1826.0]]], "lines": ["謙虚ですね。"]}, {"box": [1873, 2465, 2209, 3038], "vertical": true, "font_size": 58, "lines_coords": [[[2151.0, 2468.0], [2209.0, 2468.0], [2209.0, 2746.0], [2151.0, 2746.0]], [[2082.0, 2468.0], [2141.0, 2468.0], [2141.0, 3038.0], [2082.0, 3038.0]], [[2007.0, 2465.0], [2065.0, 2465.0], [2072.0, 2750.0], [2014.0, 2750.0]], [[1942.0, 2468.0], [2000.0, 2468.0], [2000.0, 2918.0], [1942.0, 2918.0]], [[1873.0, 2468.0], [1931.0, 2468.0], [1931.0, 2812.0], [1873.0, 2812.0]]], "lines": ["そもそもの", "デビューのきっかけは、", "高校時代の", "スカウトだったと", "聞いてますが、"]}, {"box": [1979, 3381, 2413, 3463], "vertical": false, "font_size": 90, "lines_coords": [[[1979.0, 3373.0], [2413.0, 3373.0], [2413.0, 3471.0], [1979.0, 3471.0]]], "lines": ["ＤＬ－ＲａＭ．Ｓｅ"]}, {"box": [1650, 2753, 1784, 3210], "vertical": true, "font_size": 58, "lines_coords": [[[1726.0, 2753.0], [1784.0, 2753.0], [1784.0, 3206.0], [1726.0, 3206.0]], [[1654.0, 2757.0], [1712.0, 2757.0], [1708.0, 3210.0], [1650.0, 3210.0]]], "lines": ["昔から目立つ存在", "だったんですか？"]}, {"box": [338, 3055, 466, 3412], "vertical": true, "font_size": 54, "lines_coords": [[[404.0, 3055.0], [463.0, 3055.0], [463.0, 3330.0], [404.0, 3330.0]], [[339.0, 3055.0], [387.0, 3055.0], [387.0, 3406.0], [339.0, 3406.0]]], "lines": ["いえ、全然。", "イモでしたよ。"]}], "img_path": "page_003.jpg"}]}